{
    "memory_mode": {
        "description": "记忆共享模式",
        "type": "string",
        "default": "global",
        "options": ["global", "shared"],
        "hint": "global=各群独立记忆；shared=跨群共享记忆"
    },
    "fifo_size": {
        "description": "近期对话队列长度，满后自动触发总结",
        "type": "int",
        "default": 10,
        "min": 3,
        "max": 50
    },
    "inject_fifo_in_group": {
        "description": "群聊时是否将近期未总结对话注入提示词",
        "type": "bool",
        "default": true
    },
    "auto_summary_interval_minutes": {
        "description": "自动总结间隔分钟数（-1 表示不启用，0 表示仅按队列长度触发）",
        "type": "int",
        "default": -1,
        "min": -1,
        "max": 1440
    },
    "max_memory_per_layer": {
        "description": "每层记忆最大条数",
        "type": "int",
        "default": 50,
        "min": 10,
        "max": 200
    },
    "fleeting_ttl_rounds": {
        "description": "短暂记忆存活轮数",
        "type": "int",
        "default": 3,
        "min": 1,
        "max": 20
    },
    "max_concurrent_summaries": {
        "description": "最大并发总结任务数",
        "type": "int",
        "default": 2,
        "min": 1,
        "max": 10
    },
    "summary_provider_id": {
        "description": "总结用 LLM Provider ID，留空使用主模型",
        "type": "text",
        "default": ""
    },
    "summary_system_prompt": {
        "description": "总结任务的额外系统提示词",
        "type": "text",
        "default": ""
    },
    "summary_search_replace_prompt": {
        "description": "search_replace 模式提示词模板（留空用默认）",
        "type": "text",
        "default": ""
    },
    "summary_full_replace_prompt": {
        "description": "full_replace 模式提示词模板（留空用默认）",
        "type": "text",
        "default": ""
    },
    "inject_memory_in_private": {
        "description": "私聊时是否注入三层记忆",
        "type": "bool",
        "default": true
    },
    "inject_layers_in_group": {
        "description": "群聊时注入的记忆层",
        "type": "string",
        "default": "important_only",
        "options": ["important_only", "important_general", "all"],
        "hint": "important_only=仅重要记忆；important_general=重要+一般；all=全部"
    },
    "enable_auto_summary": {
        "description": "是否启用队列满自动总结",
        "type": "bool",
        "default": true
    },
    "enable_manual_summary": {
        "description": "是否允许用户手动触发总结",
        "type": "bool",
        "default": true
    },
    "enable_llm_tools": {
        "description": "是否向 LLM 暴露记忆管理工具",
        "type": "bool",
        "default": true
    },
    "tool_caution_in_prompt": {
        "description": "是否附加工具使用警告",
        "type": "bool",
        "default": true
    }
}
